<Page x:Class="Yp2.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Yp2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <StackPanel Background="black">
    
            <Button x:Name="Catalog" Content="Каталог" Margin="0,0,0,10" Click="Catalog_Click"/>

            <Button x:Name="Books" Content="Книги" Margin="5" Click="Books_Click"/>
            <Button x:Name="Admin" Content="Админ" Visibility="Hidden" Margin="5" Click="Admin_Click" Background="DarkRed" Foreground="White"/>
            <Button x:Name="Author" Content="Автор" Visibility="Hidden" Margin="5" Click="Author_Click" />
            <Button x:Name="Profile" Content="Профиль" Margin="5" Click="Profile_Click"/>
            
            <Button x:Name="Frozen" Content="Заморозка" Visibility="Hidden" Margin="0,0,0,10" Click="Frozen_Click"/>

        </StackPanel>
        <Frame x:Name="PageFrame" Grid.Column="1"/>
    </Grid>
</Page>
