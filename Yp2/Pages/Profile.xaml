<Page x:Class="Yp2.Pages.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Yp2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profile">

    <Grid>
        <ScrollViewer Padding="20">
            <StackPanel MaxWidth="600" HorizontalAlignment="Left">

                <Border x:Name="FreezeAlert" Background="#FFE5E5" BorderBrush="Red" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="ВАШ АККАУНТ ЗАМОРОЖЕН" Foreground="Red" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="FreezeReasonText" Text="Причина: ..." TextWrapping="Wrap" Margin="0,5"/>
                        <Button Content="Оспорить заморозку" Click="UnfreezeRequest_Click" HorizontalAlignment="Left" Padding="10,5"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Личные данные" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Логин: " Grid.Row="0" Margin="5"/>
                    <TextBlock x:Name="UsernameTxt" Grid.Row="0" Grid.Column="1" Margin="5" FontWeight="Medium"/>

                    <TextBlock Text="Email: " Grid.Row="1" Margin="5"/>
                    <TextBlock x:Name="EmailTxt" Grid.Row="1" Grid.Column="1" Margin="5" FontWeight="Medium"/>

                    <TextBlock Text="Роли: " Grid.Row="2" Margin="5"/>
                    <TextBlock x:Name="RolesTxt" Grid.Row="2" Grid.Column="1" Margin="5" FontWeight="Medium"/>
                </Grid>

                <Button x:Name="BecomeAuthorBtn" Content="Стать автором" Click="BecomeAuthor_Click" 
                    Visibility="Collapsed" Padding="15,7" Margin="0,0,0,30"/>

                <TextBlock Text="Мои отзывы" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <ItemsControl x:Name="ReviewsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="10" Margin="0,5">
                                <StackPanel>
                                    <TextBlock Text="{Binding BookTitle}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding RatingDisplay}" Foreground="Orange"/>
                                    <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding CreatedAt}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
