<Page x:Class="Yp2.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Yp2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegPage">

    <Grid>
        <Button Content="Назад"
         HorizontalAlignment="Right"
         VerticalAlignment="Top"
         Height="35"
         Width="60"
         Margin="10"
         Click="BBack_Click"/>

        <StackPanel HorizontalAlignment="Center"
             VerticalAlignment="Center"
             Width="250">
            <TextBlock Text="Имя" Margin="0,0,0,5"/>
            <TextBox x:Name="Nameu" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="Фамилия" Margin="0,0,0,5"/>
            <TextBox x:Name="LastName" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="Логин" Margin="0,0,0,5"/>
            <TextBox x:Name="login" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="Пароль" Margin="0,0,0,5"/>
            <TextBox x:Name="passw" Height="30" Margin="0,0,0,10"/>

            <ComboBox x:Name="cmb" Margin="0,0,0,10"/>

            <Button Content="Зарегистрироваться"
             Height="35"
             Margin="0,0,0,10"
             Click="reg_Click"/>

            <Button Content="Есть аккаунт? Войти"
             Height="35"
             Click="enter_Click"/>
        </StackPanel>
    </Grid>
</Page>
