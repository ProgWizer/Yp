<Page x:Class="Yp2.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Yp2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookPage">

    <Grid>
        <ScrollViewer>
            <StackPanel Margin="20">

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="Gray" BorderThickness="1">
                        <!--<Image Source="{Binding CoverUrl}" x:Name="xImage" Height="300" Stretch="UniformToFill"/>-->
                        <Image x:Name="xImage" 
                           Source="{Binding CoverUrl, TargetNullValue='/Images/no-cover.png', FallbackValue='/Images/no-cover.png'}" 
                           Height="300" 
                           Stretch="UniformToFill"/>
                    </Border>


                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock x:Name="TitleText" FontSize="28" FontWeight="Bold"/>
                        <TextBlock x:Name="AuthorText" FontSize="18" Margin="0,10,0,10"/>
                        <TextBlock x:Name="GenresText" FontSize="16" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Рейтинг:" FontWeight="Bold"/>
                        <TextBlock x:Name="RatingText" FontSize="18" Margin="0,0,0,20"/>
                        <TextBlock Text="Описание:" FontWeight="Bold"/>
                        <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Width="500"/>

                        

                        <WrapPanel Margin="0,20,0,0">
                            <Button Content="Добавить в список" Width="170" Height="35" Margin="0,0,10,0" Click="AddToList_Click"/>
                            <Button Content="Пожаловаться" Width="150" Height="35" Margin="0,0,10,0" Click="ReportBook_Click"/>
                            <Button Content="Жалоба на автора" Width="170" Height="35" Margin="0,0,10,0" Click="ReportAuthor_Click" />
                            <Button x:Name="FreezeBookBtn" Content="Заморозить" Width="150" Height="35" Visibility="Collapsed" Click="FreezeBook_Click"/>
                            
                        </WrapPanel>

                    </StackPanel>
                </Grid>

                <!-- отзыв -->
                <Border BorderBrush="Gray" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Оставить отзыв" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/> 
                        <ComboBox x:Name="RatingBox" Width="100" Margin="0,0,0,10">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                        </ComboBox>

                        <TextBox x:Name="ReviewText" Height="100" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <Button x:Name="SendReviewBtn" Content="Отправить" Width="150" Height="35" Margin="0,10,0,0" Click="SendReview_Click"/>
                    </StackPanel>
                </Border>


                <TextBlock Text="Отзывы" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>
                <ItemsControl x:Name="ReviewsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Users.Username}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{Binding Rating}" Margin="0,5,0,5"/>
                                    <TextBlock Text="{Binding Comment}" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="Пожаловаться" Tag="{Binding Id}" Click="ReportReview_Click"/>
                                        <Button x:Name="FreezeReviewBtn" Content="Заморозить" Tag="{Binding Id}" Margin="10,0,0,0" Click="FreezeReview_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
