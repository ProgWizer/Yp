<Page x:Class="Yp2.Pages.EditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Yp2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EditBookPage">

    <Grid>
        <StackPanel Margin="30" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock x:Name="PageHeader" Text="Добавление книги" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Название:"/>
            <TextBox x:Name="TitleBox" Margin="0,5,0,15"/>

            <TextBlock Text="Описание:"/>
            <TextBox x:Name="DescBox" Height="150" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,15"/>

            <TextBlock Text="Ссылка на обложку (URL):"/>
            <TextBox x:Name="UrlBox" Margin="0,5,0,20"/>

            <Button Content="Сохранить" Height="40" Click="Save_Click" Background="Purple" Foreground="White"/>
        </StackPanel>
    </Grid>
</Page>
